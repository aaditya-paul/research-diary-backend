# Research Diary Backend - Environment Configuration Example
# Copy this file to .env and fill in your actual API keys

# ========================================
# PRIMARY LLM: NVIDIA NIM (Qwen 3.5-122B)
# ========================================
# Get API key at: https://build.nvidia.com/nvidia/qwen-3.5-122b
NVIDIA_NIM_API_KEY=""
NVIDIA_NIM_BASE_URL="https://integrate.api.nvidia.com/v1"
NVIDIA_NIM_MODEL="qwen/qwen3.5-122b-a10b"
# Enable extended thinking/reasoning for Qwen model (improves accuracy for complex tasks)
# Set to "true" (default) or "false" to disable thinking mode
NVIDIA_NIM_ENABLE_THINKING="true"

# ========================================
# FALLBACK LLM #1: Google Gemini
# ========================================
# Get a Google Gemini API key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=""

# ========================================
# FALLBACK LLM #2: Groq (Llama)
# ========================================
# Get API key at: https://console.groq.com/keys
GROQ_API_KEY=""

# ========================================
# FALLBACK LLM #3: Local Ollama
# ========================================
# Ollama must be running locally for this fallback
OLLAMA_URL="http://localhost:11434/api/generate"
OLLAMA_MODEL="qwen2.5:3b"

# ========================================
# Report Generation Settings
# ========================================
# Minimum words required per section
REPORT_MIN_SECTION_WORDS="250"

# Maximum number of rewrites allowed per section (1 = initial + 1 rewrite attempt)
REPORT_MAX_REWRITES="1"